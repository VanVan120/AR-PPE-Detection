# Copy to ".env" (or just export these in your shell) and fill in as needed.
# Only required when running the optional API VLM path:  python run.py --api
#
# The code reads keys from the environment; they are never hard-coded.

# Anthropic (default --api provider; api_provider: "anthropic" in config.yaml)
ANTHROPIC_API_KEY=

# Ollama (local default path) usually needs nothing. Override the host only if
# Ollama runs somewhere other than the config.yaml default:
# OLLAMA_HOST=http://localhost:11434
